# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────────────────
# THIS FILE IS FOR LOCAL REFERENCE ONLY.
# NEVER commit this file to git — it is in .gitignore.
#
# For Streamlit Community Cloud deployment:
#   1. Go to your app dashboard → Settings → Secrets
#   2. Paste the contents below (with real values filled in)
#   3. Save — Streamlit injects them as environment variables at runtime
#
# If ODDS_API_KEY is set here, the key input field is hidden from users
# and your key is used for everyone. If you leave it blank, users must
# supply their own key in the sidebar.
# ─────────────────────────────────────────────────────────────────────────────

# Optional: your own Odds API key (hides the input field from users)
# ODDS_API_KEY = "your_key_here"

# Optional: Anthropic key for AI Analysis button
# ANTHROPIC_API_KEY = "sk-ant-..."

# Database URL (SQLite default works for read-only cloud deployment)
# DATABASE_URL = "sqlite:///./data/ufc_predictor.db"
